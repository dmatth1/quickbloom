prefix=@PREFIX@
exec_prefix=${prefix}
includedir=${prefix}/include
libdir=${exec_prefix}/lib

Name: quickbloom
Description: Fast Split Block Bloom Filter for x86_64 (AVX2)
URL: https://github.com/dmatth1/quickbloom
Version: @VERSION@
Libs: -L${libdir} -lquickbloom
Libs.private: -lm
Cflags: -I${includedir}
